{
  "name": "@openmrs/esm-patient-growth-chart-app",
  "version": "1.0.0",
  "license": "MPL-2.0",
  "description": "patient-growth-chart-app frontend module for O3",
  "browser": "dist/openmrs-esm-patient-growth-chart-app.js",
  "main": "src/index.ts",
  "source": true,
  "scripts": {
    "start": "openmrs develop",
    "serve": "webpack serve --mode=development",
    "debug": "npm run serve",
    "build": "webpack --mode production --color",
    "analyze": "webpack --mode=production --env analyze=true",
    "lint": "cross-env eslint src --ext tsx,ts --fix --max-warnings=0",
    "test": "cross-env TZ=UTC jest --config jest.config.js --verbose false --passWithNoTests --color",
    "test:watch": "cross-env TZ=UTC jest --watch --config jest.config.js --color",
    "coverage": "yarn test --coverage",
    "typescript": "tsc",
    "extract-translations": "i18next 'src/**/*.component.tsx' 'src/**/*.modal.tsx' 'src/**/*.extension.tsx' 'src/**/*.workspace.tsx' 'src/**/*.hook.tsx' 'src/index.ts'",
    "test-e2e": "playwright test"
  },
  "keywords": [
    "openmrs"
  ],
  "homepage": "https://github.com/openmrs/esm-patient-growth-chart-app#readme",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openmrs/esm-patient-growth-chart-app.git"
  },
  "bugs": {
    "url": "https://github.com/openmrs/esm-patient-growth-chart-app/issues"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.2",
    "@carbon/charts-react": "^1.27.2",
    "@carbon/react": "^1.83.0"
  },
  "peerDependencies": {
    "@openmrs/esm-framework": "8.x",
